// Suppress 0035 (reserved_keyword) for the JSON-RPC `method` field.
// Suppress 0029 (unused_package) — @rpc is unused on the wasm/wasm-gc
// stub paths where fetch_request isn't available.
warnings = "-35-29"

import {
  "skmtkytr/ethbit/rpc" @rpc,
}

options(
  "is-main": true,
  targets: {
    "main.mbt": [ "js", "native" ],
    "main_stub.mbt": [ "wasm", "wasm-gc", "llvm" ],
  },
  link: {
    "native": {
      "cc-link-flags": "-lcurl",
    },
  },
)
